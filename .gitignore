# macOS
.DS_Store

# claude
.claude

# Documentation sources (Word/PDF reports)
docs/

# Research paper sources (LaTeX) — kept out of the repo
paper/


# Original and generated data
/data/simulated/*
!/data/simulated/.gitkeep

# Monte-Carlo simulation outputs (large; regenerable via prg.experiments.run_*)
data/experiments/*.csv
data/experiments/*.log

# Real-data raw files in data/real/ are KEPT in the repo:
#   - sp500_vix.csv (~270 KB)
#   - enso_sst.csv  (~28 KB)
#   - nino*.txt, oni.txt (~24 KB total, raw NOAA dumps)

# Experiment results: regenerable. Keep only small ENSO summaries
# needed for the wiki and §7 reproducibility.
results/*
!results/.gitkeep
!results/enso/
results/enso/regime_trace.csv

# Logs generated by bash scripts
logs/*
!/logs/.gitkeep

# Personal dev test scripts and programs (not versioned)
# /prg/testsDev/

# VSCodium / VSCode
exactIMM.code-workspace
.vscode/

